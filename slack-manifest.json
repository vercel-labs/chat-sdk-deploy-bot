{
  "display_information": {
    "name": "Deploy Bot",
    "description": "Trigger and manage deploys from Slack"
  },
  "features": {
    "bot_user": {
      "display_name": "deploy-bot",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/deploy",
        "description": "Start a deploy",
        "usage_hint": "[staging|production|prod]",
        "url": "https://example.com/api/webhooks/slack"
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "commands",
        "im:write",
        "channels:history",
        "channels:read",
        "groups:history",
        "groups:read",
        "im:history",
        "im:read",
        "mpim:history",
        "mpim:read",
        "users:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://example.com/api/webhooks/slack",
      "bot_events": []
    },
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://example.com/api/webhooks/slack"
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
