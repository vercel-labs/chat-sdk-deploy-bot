# Slack
# Create a Slack app at https://api.slack.com/apps
# Required scopes: chat:write, commands, im:write
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# GitHub
# Create a fine-grained PAT at https://github.com/settings/tokens
# Required permissions: actions read/write, contents read, issues write, pull requests read
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=...
GITHUB_REPO_OWNER=acme
GITHUB_REPO_NAME=webapp
GITHUB_WORKFLOW_ID=deploy.yml

# Linear (optional — omit to disable Linear integration)
# Create an API key at https://linear.app/settings/api
# LINEAR_API_KEY=lin_api_...
# LINEAR_TEAM_PREFIX=ENG
# LINEAR_PRODUCTION_STATE=Done

# Redis (Chat SDK state + Workflow)
REDIS_URL=redis://localhost:6379

# Permissions
# Comma-separated Slack user IDs
DEPLOY_PROD_ALLOWED=U123,U456,U789
DEPLOY_PROD_APPROVERS=U123,U456
